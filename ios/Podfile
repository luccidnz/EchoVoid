# CocoaPods's specs repository is huge and slow. Please use a newer version of
# CocoaPods (> 1.10) that supports CDN-based sources.
source 'https://cdn.cocoapods.org/'

platform :ios, '12.0'

# Flutter.framework handles settings for you, so you don't need to worry about
# setting the minimum deployment target in your app.
#
# If you fix the deployment target from the Podfile, you'll probably want to
# remove the `target.build_configurations.each` block below.
#
# For more information, see: https://flutter.dev/to/ios-deploy
#
# post_install do |installer|
#   installer.pods_project.targets.each do |target|
#     flutter_additional_ios_build_settings(target)
#   end
# end

# The Flutter post-install script duplicates logic that is handled by the
# flutter assemble tool.
#
# Instead of running that script, we copy the post-install script that is
# generated by the flutter tool and add it to the Pods project.
#
# For more information, see: https://github.com/flutter/flutter/issues/107168
def flutter_post_install(installer)
  # This is a workaround for a CocoaPods issue where if the Pods project is not
  # dirty, it will not be regenerated, and therefore the post-install script
  # will not be run.
  #
  # This can be removed once https://github.com/CocoaPods/CocoaPods/issues/11526
  # is resolved.
  installer.pods_project.mark_dirty!
  installer.pods_project.save
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter Pod
  flutter_application_path = '../'
  eval(File.read(File.join(flutter_application_path, '.ios', 'Flutter', 'podhelper.rb')), binding)
end
