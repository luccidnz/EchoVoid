{
  "expo": {
    "name": "EchoVoid: Spirit Communicator",
    "slug": "echovoid-app",
    "scheme": "echovoid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B0B0B"
    },
    "userInterfaceStyle": "dark",
    "android": {
      "package": "app.echovoid.spirit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B0B0B"
      },
      "permissions": [
        "RECORD_AUDIO",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-mail-composer"
    ]
  }
}
